{
  "name": "immich-monorepo",
  "version": "0.0.1",
  "description": "Monorepo for static sites",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "watch": "pnpm --filter svelte-markdown-preprocess build &&  pnpm -r --parallel run watch",
    "build": "pnpm build:packages && pnpm build:apps",
    "build:packages": "pnpm --filter \"./packages/**\" sync && pnpm --filter \"./packages/**\" build",
    "build:apps": "pnpm --filter \"./apps/**\" sync && pnpm --filter \"./apps/**\" build",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "sync": "pnpm -r sync",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "test:medium": "pnpm -r test:medium"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/eslint-config": "^10.0.0",
    "@types/node": "^25.6.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-svelte": "^3.12.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.42.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
