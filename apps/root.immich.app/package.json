{
  "name": "root.immich.app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "build": "npm run sync && vite build && node ../../bin/postbuild.js",
    "preview": "vite preview",
    "import-post": "dotenv -- uv run ../../import-post.py",
    "check": "npm run sync && svelte-check --tsconfig ./tsconfig.json",
    "uuid": "npx -y uuid v7",
    "sync": "svelte-kit sync",
    "test": "vitest",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^10.0.0",
    "@immich/svelte-markdown-preprocess": "^0.4.0",
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.0",
    "@vitest/browser": "^4.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^17.0.0",
    "luxon": "^3.7.2",
    "marked": "^17.0.0",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-icons": "^16.0.0",
    "svelte": "^5.39.5",
    "svelte-check": "^4.3.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.44.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.0"
  },
  "dependencies": {
    "@immich/ui": "^0.70.0",
    "@mdi/js": "^7.4.47",
    "feed": "^5.1.0",
    "front-matter": "^4.0.2",
    "svelte-highlight": "^7.8.4"
  }
}
